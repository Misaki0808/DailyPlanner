{
  "expo": {
    "name": "DailyPlanner",
    "slug": "DailyPlanner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dailyplanner.app"
    },
    "android": {
      "package": "com.dailyplanner.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow DailyPlanner to access your microphone to recognize speech.",
          "speechRecognitionPermission": "Allow DailyPlanner to recognize your speech."
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "DailyPlannerWidget",
              "label": "Günün Planı",
              "description": "Bugünkü görevlerinin özeti",
              "minWidth": "320dp",
              "minHeight": "120dp",
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ]
  }
}